rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Checks if the logged-in user matches the document path ID
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: Checks if the logged-in user has the "admin" custom claim
    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == "admin";
    }

    // ─── USER PROFILE RULES ───
    match /users/{userId} {
      // Users can read/write their own profiles; Admins can read everything
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin(); // Only admins can delete profiles

      // ─── NESTED MEALS & SETTINGS ───
      // Automatically inherits owner checks for all nested subcollections
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // ─── GLOBAL CONFIGS (Read-only for all, write for Admin) ───
    match /system_config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
